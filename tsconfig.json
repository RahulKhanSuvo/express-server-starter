{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "5.0",
    "types": ["bun"],
    "strict": true,
    "rootDir": "./src"
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "prisma.config.ts"]
}